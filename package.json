{
  "name": "@axonpush/sdk",
  "version": "0.0.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integrations/*": {
      "import": "./dist/integrations/*.js",
      "types": "./dist/integrations/*.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/axonpush/ts-sdk"
  },
  "files": ["dist"],
  "scripts": {
    "codegen": "curl -fsS http://localhost:3000/swagger/json | python3 -m json.tool > spec/openapi.json && bun run tools/patch-spec.ts spec/openapi.json && rm -rf src/_internal/api && bunx @hey-api/openapi-ts -f openapi-ts.config.ts && sed -i \"s|from '../transport.ts'|from '../transport.js'|\" src/_internal/api/client.gen.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ index.ts",
    "lint:fix": "biome check --write src/ index.ts",
    "format": "biome format --write src/ index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@hey-api/openapi-ts": "^0.97.0",
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "@vitest/ui": "^4.1.4",
    "msw": "^2.13.2",
    "vitest": "^4.1.4",
    "winston-transport": "^4.7.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-trace-base": "^1.18.0",
    "bullmq": "^5",
    "pino": "^9.0.0",
    "typescript": "^5",
    "winston": "^3.11.0",
    "winston-transport": "^4.7.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "pino": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "winston": {
      "optional": true
    },
    "winston-transport": {
      "optional": true
    }
  }
}
